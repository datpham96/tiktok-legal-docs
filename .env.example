# Server Configuration
PORT=3000
# BASE_URL phải là public HTTPS URL nếu dùng TikTok OAuth
# Ví dụ: https://abc123.ngrok-free.app hoặc https://your-tunnel-id.loca.lt
BASE_URL=https://your-ngrok-url.ngrok-free.app

# TikTok OAuth Configuration
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# TIKTOK_REDIRECT_URI phải khớp với redirect URI đã đăng ký trong TikTok Developer Portal
# TikTok KHÔNG hỗ trợ localhost, phải dùng public HTTPS URL
TIKTOK_REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/callback/tiktok

# 9router LLM Configuration
ROUTER9_BASE_URL=https://api.9router.com
ROUTER9_API_KEY=
ROUTER9_MODEL=gpt-4o-mini
ROUTER9_PROVIDER=openai

# OpenAI Configuration (for DALL-E image generation)
OPENAI_API_KEY=
