# Server Configuration
PORT=3000
# Production:
# BASE_URL=https://autopublisher.click
# TIKTOK_REDIRECT_URI=https://autopublisher.click/callback/tiktok
BASE_URL=https://your-ngrok-url.ngrok-free.app

# TikTok OAuth Configuration
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# TIKTOK_REDIRECT_URI must match TikTok Developer Portal exactly
TIKTOK_REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/callback/tiktok

# 9router LLM Configuration
ROUTER9_BASE_URL=https://api.9router.com
ROUTER9_API_KEY=
ROUTER9_MODEL=gpt-4o-mini
ROUTER9_PROVIDER=openai

# OpenAI Configuration (for DALL-E image generation)
OPENAI_API_KEY=
